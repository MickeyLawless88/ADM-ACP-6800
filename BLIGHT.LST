0000                  2  ; =============================================================================
0000                  3  ; B L I G H T   --  ADM-31 plugin ROM ($E000-$E7FF)
0000                  4  ;
0000                  5  ; PREMISE:
0000                  6  ;   Ark-ship MERIDIAN, grow-deck 4.  A spore-blight is loose in the crop
0000                  7  ;   trays and creeps to the next crops every cycle.  You pilot containment
0000                  8  ;   drone B-7.  Moving onto a tray SCORCHES it to bare deck -- a firebreak
0000                  9  ;   the blight cannot cross.  Burn lines, starve the blight, save the harvest.
0000                 10  ;
0000                 11  ;   Cells:  Y crop (fuel)   * blight   x dead tray   . bare deck   @ drone
0000                 12  ;   Each cycle the blight spreads one tray in each direction into adjacent
0000                 13  ;   crops; spent blight burns out to dead (x).  Game ends when no blight
0000                 14  ;   remains.  Score = crops still standing.
0000                 15  ;
0000                 16  ; Build/run:  assemble with acp6800 (pad 2048), load as --romA in adm31emu.
0000                 17  ; =============================================================================
0000                 18  
0000  =7000        19  HALT            EQU     $7000           ; VSYNC strobe (write before CRTRAM)
0000  =7800        20  PIA1            EQU     $7800           ; keyboard scan / strobe (bit7)
0000  =7802        21  PIA1B           EQU     $7802           ; SHIFT(bit7)/CTRL(bit6)
0000  =8000        22  CRTRAM          EQU     $8000           ; 80x24 display RAM
0000  =EA1A        23  KBDTAB          EQU     $EA1A           ; firmware keycode table {unsh,sh}
0000                 24  
0000                 25  ; ---- zero page state ----
0000                 26  
