E8B2                187  ; =============================================================================
E8B2                188  ; OUT1CH  --  print char in A to the ADM-31 screen at the cursor.
E8B2                189  ;   Preserves B and X (X via SAVEX, since 6800 has no PSHX).  CR = newline,
E8B2                190  ;   LF ignored, BS erases one cell.  Uses the verified HALT/NOP write pattern.
E8B2                191  ; =============================================================================
E8B2                192  OUT1CH
E8B2  DF 5A         193          STX     SAVEX
E8B4  37            194          PSHB
E8B5  16            195          TAB                         ; B = char
E8B6  C1 0D         196          CMPB    #$0D
E8B8  27 21         197          BEQ     OC_CR
E8BA  C1 0A         198          CMPB    #$0A
E8BC  27 22         199          BEQ     OC_LF
E8BE  C1 08         200          CMPB    #$08
E8C0  27 20         201          BEQ     OC_BS
E8C2  F7 70 00      202          STAB    HALT                ; sync strobe
E8C5  01            203          NOP
E8C6  DE 4C         204          LDX     CURPTR
E8C8  E7 00         205          STAB    $00,X
E8CA  08            206          INX
E8CB  DF 4C         207          STX     CURPTR
