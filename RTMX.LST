E917                254  ; IN1CHR  --  wait for a key, return ASCII in A.  Echoes to screen.
E917                255  ;   Native keyboard scan + decode (replicates stock ROM B $EE06 scan/decode
E917                256  ;   using the embedded KBTAB scancode table).  Preserves B and X.
E917                257  ; =============================================================================
E917                258  IN1CHR
E917  DF 5C         259          STX     SAVEX2
E919  37            260          PSHB
E91A                261  INC_SCAN
E91A  96 4F         262          LDAA    KSCAN
E91C  B7 78 00      263          STAA    PIA1                ; select scan row (PIA1_DA)
E91F  B6 78 00      264          LDAA    PIA1                ; read back (bit7 = key down)
E922  2B 09         265          BMI     INC_FOUND
E924  26 02         266          BNE     INC_DEC             ; readback nonzero -> advance position
E926  86 58         267          LDAA    #$58                ; readback 0 (pos wrapped) -> reload sentinel
E928                268  INC_DEC
E928  4A            269          DECA                        ; next position ($58 sentinel -> $57 first real)
E929  97 4F         270          STAA    KSCAN
E92B  20 ED         271          BRA     INC_SCAN            ; block until a key is down
E92D                272  INC_FOUND
E92D  F6 78 02      273          LDAB    PIA1+2              ; PIA1_DB column/modifiers
E930  D7 50         274          STAB    KMOD
E932  58            275          ASLB
E933  49            276          ROLA                        ; A = table index
E934  CE EB 2D      277          LDX     #KBTAB
E937  DF 52         278          STX     KPTR
E939  9B 53         279          ADDA    KPTR+1
E93B  97 53         280          STAA    KPTR+1
E93D  24 03         281          BCC     INC_NOCY
E93F  7C 00 52      282          INC     KPTR
E942                283  INC_NOCY
E942  DE 52         284          LDX     KPTR
E944  A6 00         285          LDAA    $00,X               ; scancode table entry
E946  4D            286          TSTA
E947  2B 20         287          BMI     INC_STORE           ; bit7 set -> special key, use as-is
E949  D6 50         288          LDAB    KMOD
E94B  C5 01         289          BITB    #$01                ; shift?
E94D  27 0A         290          BEQ     INC_CTRL
E94F  81 61         291          CMPA    #$61
E951  2D 06         292          BLT     INC_CTRL
E953  81 7A         293          CMPA    #$7A
E955  2E 02         294          BGT     INC_CTRL
