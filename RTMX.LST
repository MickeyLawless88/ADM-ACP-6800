ASSEMBLY LISTING - SOURCE FILE RTMX.ASM

ADDR  CODE        LINE  SOURCE STATEMENT
----  ----------  ----  ----------------
0000                  2  ; =============================================================================
0000                  3  ; RT/68MX  --  ADM-31 / Lear Siegler adaptation  (crasm, 6800)
0000                  4  ; ROM B plug-in slot, $E800-$EFFF (2KB, 2716)
0000                  5  ;
0000                  6  ; Assemble:  crasm -o rt68mx.srec rt68mx.asm
0000                  7  ; Binary:    srec_cat rt68mx.srec -o rt68mx.bin -binary   (-> $E800-$EFFF, 2KB)
0000                  8  ;
0000                  9  ; Adapted from the Microware RT/68MX console monitor (c)1976,1977.
0000                 10  ; This build is the MONITOR ONLY (no real-time multitasking executive):
0000                 11  ;   - native console = ADM-31 keyboard (PIA1 scan/decode) + CRTRAM screen
0000                 12  ;   - boots directly at reset (ADM-31 RST/SWI/NMI vectors -> $E800)
0000                 13  ;   - keeps stock ROM C/D physically present (not called)
0000                 14  ;
0000                 15  ; DROPPED vs. the original:  RT executive (S cmd, task table, scheduler),
0000                 16  ;   interrupt handlers, paper-tape LOAD/PUNCH (L/P), the PIA software-UART and
0000                 17  ;   ACIA serial console paths.  Everything below is plain 6800 (no 6801 ops).
0000                 18  ;
0000                 19  ; COMMANDS:  M <,addr>  examine/change      D <,beg><,end>  dump
0000                 20  ;            E <,addr>  execute (JMP)       G               go / resume (RTI)
0000                 21  ;            B <,addr>  set breakpoint      R               register/stack dump
0000                 22  ;            <ESC>      restart monitor
0000                 23  ;
0000                 24  ; Address entry is comma-led, MIKBUG style:  e.g.  D,0100,01FF<CR>
0000                 25  ;
0000                 26  ; BREAKPOINTS (B/G):  these use SWI ($3F).  The ADM-31's SWI vector lives in
0000                 27  ;   ROM D and normally points at $E800.  To enable breakpoints, patch ROM D's
0000                 28  ;   SWI_VEC to the RUNBKP address reported by crasm (see notes file).  Without
0000                 29  ;   that patch, M/D/E/R and the console all work; only B/G need it.
0000                 30  ; =============================================================================
0000                 31  
0000                 32  
0000                 33  
0000                 34  ; ----------------------------------------------------------------------------
0000                 35  ; ADM-31 hardware (Table 4-1)
0000                 36  ; ----------------------------------------------------------------------------
0000  =7000        37  HALT            EQU     $7000       ; video-sync strobe (write anything)
0000  =7800        38  PIA1            EQU     $7800       ; DA=$7800 CRA=$7801 DB=$7802 CRB=$7803
0000  =7E00        39  SW_BNK1         EQU     $7E00       ; strap/switch register
0000  =7F00        40  VTAC            EQU     $7F00       ; video timing controller base
0000  =8000        41  CRTRAM          EQU     $8000       ; screen RAM
0000                 42  
0000  =0050        43  SCRSTRIDE       EQU     80          ; bytes per screen row (verified: $50)
0000  =0050        44  SCRCOLS         EQU     80          ; visible columns
0000  =8780        45  SCREND          EQU     $8780       ; one past last visible cell ($8000+24*80)
0000  =8730        46  LASTROW         EQU     $8730       ; start of bottom row ($8000+23*80)
0000  =0730        47  SCRCNT          EQU     1840        ; bytes to move on scroll (23*80)
0000                 48  
0000                 49  ; ----------------------------------------------------------------------------
0000                 50  ; RAM layout  (ADM-31 has RAM only at $0000-$03FF; original used $A000)
0000                 51  ;   monitor variables in page 0 (direct addressing); CPU stack high in page 1
0000                 52  ; ----------------------------------------------------------------------------
0000  =0040        53  BEGADR          EQU     $40         ; 2  dump start / current
0000  =0042        54  ENDADR          EQU     $42         ; 2  dump end / BADDR result / M addr
0000  =0044        55  SPTMP           EQU     $44         ; 2  saved user stack pointer
0000  =0046        56  BKPADR          EQU     $46         ; 2  breakpoint address
0000  =0048        57  BKPOP           EQU     $48         ; 1  breakpoint opcode/flag
0000  =0049        58  RTMOD           EQU     $49         ; 1  run mode (monitor: 0)
0000  =004B        59  ERRFLG          EQU     $4B         ; 1  error flag/code
0000  =004C        60  CURPTR          EQU     $4C         ; 2  screen cursor CRTRAM address
0000  =004E        61  CURCOL          EQU     $4E         ; 1  cursor column 0..79
0000  =004F        62  KSCAN           EQU     $4F         ; 1  keyboard scan position
0000  =0050        63  KMOD            EQU     $50         ; 1  keyboard modifier latch (PIA1_DB)
0000  =0051        64  KCHAR           EQU     $51         ; 1  decoded key
0000  =0052        65  KPTR            EQU     $52         ; 2  keyboard-table index scratch
0000  =0054        66  MSRC            EQU     $54         ; 2  scroll source ptr
0000  =0056        67  MDST            EQU     $56         ; 2  scroll dest ptr
0000  =0058        68  MCNT            EQU     $58         ; 2  scroll counter
0000  =005A        69  SAVEX           EQU     $5A         ; 2  X save (OUT1CH) - no PSHX on 6800
0000  =005C        70  SAVEX2          EQU     $5C         ; 2  X save (IN1CHR)
0000                 71  
0000  =01FF        72  STACK           EQU     $01FF       ; CPU stack top (grows down, page 1)
0000                 73  
0000                 74  ; =============================================================================
E800                 75          ORG $E800
E800                 76  ; =============================================================================
E800                 77  ; RESET  --  ADM-31 reset/SWI/NMI vector to $E800; we own the machine.
E800                 78  ;   Replicates the stock ROM B power-on bring-up (VTAC + PIA1) since the stock
E800                 79  ;   ROM B no longer runs, then enters the monitor.
E800                 80  ; =============================================================================
E800                 81  RESET
E800  0F             82          SEI
E801  8E 01 FF       83          LDS     #STACK
