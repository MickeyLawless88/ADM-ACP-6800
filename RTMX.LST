E8D0  96 4E         209          LDAA    CURCOL
E8D2  81 50         210          CMPA    #SCRCOLS
E8D4  26 20         211          BNE     OC_RET
E8D6  BD E8 FA      212          JSR     OC_NL
E8D9  20 1B         213          BRA     OC_RET
E8DB                214  OC_CR
E8DB  BD E8 FA      215          JSR     OC_NL
E8DE  20 16         216          BRA     OC_RET
